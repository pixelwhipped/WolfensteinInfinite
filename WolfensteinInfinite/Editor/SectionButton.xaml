<UserControl x:Class="WolfensteinInfinite.Editor.SectionButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WolfensteinInfinite.Editor"
             mc:Ignorable="d" 
             d:DesignHeight="64" d:DesignWidth="64" Background="Gray" BorderBrush="Black" BorderThickness="1" MouseDown="Image_MouseDown">
    <Grid x:Name="MainGrid">
        <Image x:Name="Image" Width="64" Height="64"/>
        <TextBlock x:FieldModifier="public" x:Name="Details" Foreground="Black" FontSize="12" FontWeight="DemiBold"></TextBlock>
    </Grid>
</UserControl>
