<Window x:Class="WolfensteinInfinite.Editor.MapEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WolfensteinInfinite.Editor"
        mc:Ignorable="d"
        Title="MapEditor" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid  Background="Black">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"  VerticalAlignment="Center">
                <ComboBox x:Name="ModSelection" Width="150" SelectionChanged="ModSelection_SelectionChanged"/>
                <ComboBox x:Name="MapSectionSelection" Width="60" SelectionChanged="MapSectionSelection_SelectionChanged"/>
                <Label Content="Min Level"/>
                <Slider x:Name="MinLevelSld" Minimum="1" Maximum="100" Width="200" ValueChanged="MinLevelSld_ValueChanged"/>
                <Button x:Name="DeleteBtn" Content="Delete" IsEnabled="False" Click="DeleteBtn_Click"/>
                <Button x:Name="DuplicateBtn" Content="Duplicate" IsEnabled="False" Click="DuplicateBtn_Click"/>
                <ComboBox x:Name="DifficultySelection" Width="150" SelectionChanged="DifficultySelection_SelectionChanged"/>
                <Button x:Name="SaveBtn" Content="Save" IsEnabled="False" Click="SaveBtn_Click"/>
                <Button x:Name="SaveAllBtn" Content="Save All" IsEnabled="False" Click="SaveAllBtn_Click"/>
                <Button x:Name="TestBtn" Content="Test" IsEnabled="False" Click="TestBtn_Click" Visibility="Hidden"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.8*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="0.2*"/>
            </Grid.ColumnDefinitions>


            <ScrollViewer x:Name="CurrentMapView" Background="Black" Grid.Row="1" HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Visible" PreviewMouseWheel="CurrentMapView_PreviewMouseWheel" >
                <Grid x:Name="SectionGrid" Width="4096" Height="4096" RenderTransformOrigin="0.5,0.5" >
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="SectionGridScale"  ScaleX="1" ScaleY="1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                </Grid>
            </ScrollViewer>
            <GridSplitter Width="5" Grid.Column="1" HorizontalAlignment="Center"
              VerticalAlignment="Stretch"
              Background="Black" 
              ShowsPreview="True"/>
            <TabControl x:Name="LayerControl" MinWidth="200" Grid.Column="2">
                <TabItem x:Name="LayerWallsControl" Header="Walls">
                    <ScrollViewer >
                        <WrapPanel  x:Name="WallTextureImageGrid" Orientation="Horizontal" ></WrapPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem x:Name="LayerDecalsControl" Header="Decals">
                    <ScrollViewer >
                        <WrapPanel  x:Name="DecalTextureImageGrid" Orientation="Horizontal" ></WrapPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem x:Name="LayerItemsControl" Header="Items">
                    <ScrollViewer >
                        <WrapPanel  x:Name="ItemTextureImageGrid" Orientation="Horizontal" ></WrapPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem x:Name="LayerEnemiesControl" Header="Enemy">
                    <ScrollViewer >
                        <WrapPanel  x:Name="EnemyTextureImageGrid" Orientation="Horizontal" ></WrapPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem x:Name="LayerDoorControl" Header="Doors">
                    <ScrollViewer >
                        <WrapPanel  x:Name="DoorTextureImageGrid" Orientation="Horizontal" ></WrapPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem x:Name="LayerSpecialControl" Header="Special">
                    <ScrollViewer >
                        <WrapPanel  x:Name="SpecialTextureImageGrid" Orientation="Horizontal" ></WrapPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
